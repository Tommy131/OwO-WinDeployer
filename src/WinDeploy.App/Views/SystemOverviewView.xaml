<UserControl x:Class="WinDeploy.App.Views.SystemOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="系统概览" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="本机硬件 / 系统健康实时一览：CPU、内存、功耗、磁盘（含 SMART）、电池、激活状态（每 2 秒刷新）。" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="↻ 刷新" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
      <Button Content="导出软件清单" Style="{StaticResource InfoButton}" Margin="8,0,0,0" Command="{Binding ExportInventoryCommand}" />
      <Button Content="🛡 以管理员身份运行" Style="{StaticResource WarnButton}" Margin="8,0,0,0"
              Command="{Binding RelaunchAdminCommand}"
              Visibility="{Binding ShowAdminHint, Converter={StaticResource BoolToVis}}"
              ToolTip="以管理员重启后才能读取 CPU 温度与 CPU/主板功耗（AMD MSR/SMU 经 WinRing0 驱动，需管理员）" />
      <TextBlock Text="{Binding InventoryNote}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                 VerticalAlignment="Center" Margin="14,0,0,0" TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar sits flush at the page's outer edge while content stays put. -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,14,-24,0" Padding="0,0,24,0">
      <StackPanel>
        <!-- Summary card -->
        <Border Style="{StaticResource Card}" Padding="18,14">
          <StackPanel>
            <TextBlock Text="{Binding Os}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Machine}" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap" />
            <Separator Margin="0,12" Background="{DynamicResource BorderSoft}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="处理器" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock Text="{Binding Cpu}" FontSize="13" TextWrapping="Wrap" Margin="0,2,12,2" />
                <TextBlock Text="{Binding CpuLive}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="0,0,12,10" />
                <Grid Margin="0,0,12,0">
                  <TextBlock Text="内存" FontSize="11" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border CornerRadius="6" Padding="6,1" Margin="0,0,8,0" Background="{DynamicResource FailBg}" VerticalAlignment="Center"
                            Visibility="{Binding RamHigh, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="占用偏高" FontSize="10" Foreground="{DynamicResource FailFg}" />
                    </Border>
                    <TextBlock Text="{Binding RamPercentText}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" />
                  </StackPanel>
                </Grid>
                <ProgressBar Value="{Binding RamPercent, Mode=OneWay}" Maximum="100" Height="6" Margin="0,5,12,5"
                             Background="{DynamicResource PageBg}" Foreground="{DynamicResource Accent}" BorderThickness="0" />
                <TextBlock Text="{Binding RamLive}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,12,10" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="运行时间" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock Text="{Binding Uptime}" FontSize="13" Margin="0,2,0,10" />
                <TextBlock Text="激活 / 电池" FontSize="11" Foreground="{DynamicResource TextTertiary}" />
                <TextBlock FontSize="13" Margin="0,2,0,10">
                  <Run Text="{Binding Activation}" /><Run Text="  ·  " /><Run Text="{Binding Battery}" />
                </TextBlock>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Power monitoring -->
        <Grid Margin="2,18,0,8">
          <TextBlock Text="系统功耗 · 实时" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Border CornerRadius="8" Padding="12,4" HorizontalAlignment="Right" Background="{DynamicResource AccentBg}"
                  Visibility="{Binding HasPower, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="整机功耗" FontSize="11.5" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" />
              <TextBlock Text="{Binding TotalPowerText}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
            </StackPanel>
          </Border>
        </Grid>
        <Border Style="{StaticResource Card}" Padding="14,12">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding Powers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,9" ToolTip="{Binding BarTip}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="52" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="6" Padding="7,2" Background="{DynamicResource AccentBg}" HorizontalAlignment="Left" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Kind}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis" />
                      <ProgressBar Value="{Binding BarPercent, Mode=OneWay}" Maximum="100" Height="5" Margin="0,4,0,0"
                                   Background="{DynamicResource PageBg}" Foreground="{DynamicResource Accent}" BorderThickness="0" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding WattsText}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding PowerNote}" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Drives -->
        <TextBlock Text="磁盘空间" FontSize="14" FontWeight="SemiBold" Margin="2,18,0,8" />
        <ItemsControl ItemsSource="{Binding Disks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,11" Margin="0,0,0,8">
                <StackPanel>
                  <Grid>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Drive}" FontSize="14" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0" VerticalAlignment="Center" />
                      <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource FailBg}" VerticalAlignment="Center"
                              Visibility="{Binding Low, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="空间偏低" FontSize="10" Foreground="{DynamicResource FailFg}" />
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Text}" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" />
                  </Grid>
                  <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100" Height="6" Margin="0,8,0,0"
                               Background="{DynamicResource PageBg}" Foreground="{DynamicResource Accent}" BorderThickness="0" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Physical disks / SMART (点击磁盘查看 SMART 详情) -->
        <TextBlock Text="物理磁盘健康 (SMART) · 点击磁盘查看详情" FontSize="14" FontWeight="SemiBold" Margin="2,14,0,8" />
        <ItemsControl ItemsSource="{Binding PhysicalDisks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,8" Cursor="Hand"
                      ToolTip="点击查看该磁盘的 SMART / 可靠性数据">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick"
                                Command="{Binding DataContext.ShowSmartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Detail}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0" />
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- top-right: health + chevron -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <Border CornerRadius="6" Padding="9,3" Background="{DynamicResource OkBg}">
                        <TextBlock Text="{Binding Health}" FontSize="12" Foreground="{DynamicResource OkFg}" />
                      </Border>
                      <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                 Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <!-- bottom-right: interface / media type badge (NVMe / SSD / HDD / USB …) -->
                    <Border CornerRadius="6" Padding="9,2" Margin="0,7,0,0" HorizontalAlignment="Right"
                            Background="{DynamicResource AccentBg}">
                      <TextBlock Text="{Binding TypeLabel}" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{DynamicResource Accent}" />
                    </Border>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
