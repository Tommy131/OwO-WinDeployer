<UserControl x:Class="WinDeploy.App.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Button Grid.Row="0" Content="← 返回" Command="{Binding BackCommand}"
            HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
      <Grid Width="56" Height="56">
        <Border CornerRadius="12" Background="{Binding ChipBackground}"
                Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding Badge}" FontSize="26" FontWeight="SemiBold" Foreground="{Binding ChipForeground}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="3"
               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
               RenderOptions.BitmapScalingMode="HighQuality" />
      </Grid>
      <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Border CornerRadius="10" Padding="9,2" Margin="10,0,0,0" VerticalAlignment="Center" Background="{StaticResource PageBg}">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
          </Border>
        </StackPanel>
        <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" />
      </StackPanel>
    </StackPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="18" Margin="0,16,0,0" VerticalAlignment="Top">
      <StackPanel>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="版本" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="大小" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Size}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="安装日期" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding InstallDate}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="发布者" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Publisher}" FontSize="13" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="来源" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding Source}" FontSize="13" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="标识" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" Text="{Binding PackageId}" FontSize="13" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="官网" FontSize="13" Foreground="{StaticResource TextSecondary}" />
          <TextBlock Grid.Column="1" FontSize="13" TextTrimming="CharacterEllipsis">
            <Hyperlink Command="{Binding OpenHomepageCommand}"><Run Text="{Binding Homepage, Mode=OneWay}" /></Hyperlink>
          </TextBlock>
        </Grid>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
