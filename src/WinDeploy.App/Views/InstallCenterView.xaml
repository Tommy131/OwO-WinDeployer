<UserControl x:Class="WinDeploy.App.Views.InstallCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header / top bar -->
    <Grid Grid.Row="0" Margin="24,18,24,8">
      <StackPanel>
        <TextBlock Text="软件安装中心" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <TextBox Width="150" Height="32" VerticalContentAlignment="Center" Padding="8,0"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <ComboBox Width="120" Height="32" Margin="8,0,0,0"
                  ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" />
        <Button Content="{Binding StartLabel}" Style="{StaticResource PrimaryButton}"
                Margin="8,0,0,0" Command="{Binding StartCommand}" />
      </StackPanel>
    </Grid>

    <!-- Error banner -->
    <Border Grid.Row="1" Margin="24,8" VerticalAlignment="Top" Padding="14,10" CornerRadius="8"
            Background="{StaticResource FailBg}"
            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="{Binding LoadError}" Foreground="{StaticResource FailFg}" TextWrapping="Wrap" />
    </Border>

    <!-- Loading（先检测完已安装状态，再显示列表） -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
      <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                   Foreground="{StaticResource Accent}" Background="{StaticResource PageBg}" BorderThickness="0" />
      <TextBlock Text="正在检测已安装软件 …" FontSize="13" Foreground="{StaticResource TextSecondary}"
                 HorizontalAlignment="Center" Margin="0,12,0,0" />
    </StackPanel>

    <!-- Category groups -->
    <ScrollViewer x:Name="Scroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,4,18,18"
                  ScrollChanged="Scroller_ScrollChanged"
                  Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,6"
                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
              <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="{Binding CountText}" FontSize="12" Foreground="{StaticResource TextTertiary}"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
              </StackPanel>

              <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource Card}" Width="158" MinHeight="150" Margin="0,0,10,10" Padding="12"
                            Cursor="Hand"
                            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                      <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}" />
                      </Border.InputBindings>
                      <StackPanel>
                        <Grid>
                          <Grid Width="36" Height="36" HorizontalAlignment="Left">
                            <Border CornerRadius="8" Background="{Binding ChipBackground}"
                                    Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
                              <TextBlock Text="{Binding Badge}" FontSize="17" FontWeight="SemiBold"
                                         Foreground="{Binding ChipForeground}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="2"
                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                          </Grid>
                          <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Right" VerticalAlignment="Top" />
                        </Grid>
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Margin="0,9,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap" Height="32" Margin="0,2,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                          <Border Background="{StaticResource PageBg}" CornerRadius="6" Padding="6,2">
                            <TextBlock Text="{Binding Method}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                          </Border>
                          <Border CornerRadius="6" Padding="6,2" Margin="5,0,0,0" Background="{StaticResource OkBg}"
                                  Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource OkFg}" />
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
