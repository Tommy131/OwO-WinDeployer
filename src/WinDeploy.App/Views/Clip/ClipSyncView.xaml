<UserControl x:Class="WinDeploy.App.Views.Clip.ClipSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="{DynamicResource S.clip.page.title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="{DynamicResource S.clip.page.subtitle}"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <!-- tab bar -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
      <ToggleButton Content="{DynamicResource S.clip.tab.peers}" Style="{StaticResource MiniToggle}" Margin="0,0,8,0"
                    IsChecked="{Binding IsPeersTab, Mode=OneWay}" Command="{Binding ShowPeersCommand}" />
      <ToggleButton Content="{DynamicResource S.clip.tab.board}" Style="{StaticResource MiniToggle}" Margin="0,0,8,0"
                    IsChecked="{Binding IsBoardTab, Mode=OneWay}" Command="{Binding ShowBoardCommand}" />
      <ToggleButton Content="{DynamicResource S.clip.tab.settings}" Style="{StaticResource MiniToggle}"
                    IsChecked="{Binding IsSettingsTab, Mode=OneWay}" Command="{Binding ShowSettingsCommand}" />
    </StackPanel>

    <ContentControl Grid.Row="2" Content="{Binding Current}" Margin="0,14,0,0"
                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
  </Grid>
</UserControl>
