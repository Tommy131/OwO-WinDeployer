<UserControl x:Class="WinDeploy.App.Views.Clip.ClipSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="640" HorizontalAlignment="Left">

      <!-- identity -->
      <Border Style="{StaticResource Card}" Padding="16,14">
        <StackPanel>
          <TextBlock Text="{DynamicResource S.clip.settings.sectionIdentity}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
          <TextBlock Text="{DynamicResource S.clip.settings.deviceName}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,12,0,4" />
          <TextBox Text="{Binding DeviceName}" Padding="8,6" />
          <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
              <TextBlock Text="{DynamicResource S.clip.settings.port}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4" />
              <TextBox Text="{Binding PortText}" Padding="8,6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
              <TextBlock Text="{DynamicResource S.clip.settings.discoveryPort}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4" />
              <TextBox Text="{Binding DiscoveryPortText}" Padding="8,6" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- behavior -->
      <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,12,0,0">
        <StackPanel>
          <TextBlock Text="{DynamicResource S.clip.settings.sectionBehavior}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
          <CheckBox IsChecked="{Binding AutoApply}" Content="{DynamicResource S.clip.settings.autoApply}" Margin="0,12,0,0" />
          <TextBlock Text="{DynamicResource S.clip.settings.autoApplyHint}" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" Margin="22,3,0,0" TextWrapping="Wrap" />
          <CheckBox IsChecked="{Binding PersistHistory}" Content="{DynamicResource S.clip.settings.persist}" Margin="0,12,0,0" />
          <TextBlock Text="{DynamicResource S.clip.settings.persistHint}" FontSize="11.5" Foreground="{DynamicResource TextTertiary}" Margin="22,3,0,0" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- limits -->
      <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,12,0,0">
        <StackPanel>
          <TextBlock Text="{DynamicResource S.clip.settings.sectionLimits}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
          <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
              <TextBlock Text="{DynamicResource S.clip.settings.historyLimit}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4" />
              <TextBox Text="{Binding HistoryLimitText}" Padding="8,6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
              <TextBlock Text="{DynamicResource S.clip.settings.maxImageMb}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4" />
              <TextBox Text="{Binding MaxImageMbText}" Padding="8,6" />
            </StackPanel>
          </Grid>
          <TextBlock Text="{Binding CapInfo}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}" Margin="0,12,0,0" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Button Content="{DynamicResource S.clip.settings.save}" Style="{StaticResource PrimaryButton}"
              HorizontalAlignment="Left" Margin="0,14,0,0" Command="{Binding SaveCommand}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
