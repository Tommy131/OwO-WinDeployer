<UserControl x:Class="WinDeploy.App.Views.Clip.ClipBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- toolbar: manual add + count + clear -->
    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" Text="{Binding NewText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"
                 Padding="8,6" Tag="{DynamicResource S.clip.board.addPlaceholder}" />
        <Button Grid.Column="1" Content="{DynamicResource S.clip.board.add}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Command="{Binding AddCommand}" />
        <TextBlock Grid.Column="2" Text="{Binding CountText}" VerticalAlignment="Center" Margin="14,0,8,0"
                   FontSize="12.5" Foreground="{DynamicResource TextTertiary}" />
        <Button Grid.Column="3" Content="{DynamicResource S.clip.board.clear}" Style="{StaticResource MiniButton}" Command="{Binding ClearCommand}" />
      </Grid>
    </Border>

    <!-- list + preview -->
    <Grid Grid.Row="1" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.1*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- entries -->
      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="2" Margin="0,0,6,0">
        <Grid>
          <TextBlock Text="{DynamicResource S.clip.board.empty}" FontSize="13" Foreground="{DynamicResource TextTertiary}"
                     Margin="14,12,14,0" TextWrapping="Wrap" VerticalAlignment="Top"
                     Visibility="{Binding NoEntries, Converter={StaticResource BoolToVis}}" />
          <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding Selected}" Background="Transparent"
                   BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="4">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border x:Name="B" Background="{DynamicResource PageBg}" CornerRadius="8" Padding="11,9">
                        <ContentPresenter />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter TargetName="B" Property="Background" Value="{DynamicResource AccentBg}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="B" Property="Background" Value="{DynamicResource AccentBg}" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Image Grid.Column="0" Source="{Binding Image}" Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,10,0"
                         Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}" />
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Preview}" FontSize="13" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,3,0,0">
                      <Run Text="{Binding TypeText, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding OriginName, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding TimeText, Mode=OneWay}" />
                    </TextBlock>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{DynamicResource S.clip.board.copy}" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding CopyCommand}" />
                    <Button Content="{DynamicResource S.clip.board.delete}" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- preview pane -->
      <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14" Margin="6,0,0,0">
        <Grid>
          <TextBlock Text="{DynamicResource S.clip.board.previewHint}" FontSize="13" Foreground="{DynamicResource TextTertiary}"
                     VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasSelection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <!-- text preview -->
          <TextBox Text="{Binding Selected.PreviewText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                   BorderThickness="0" Background="Transparent" FontSize="13"
                   VerticalScrollBarVisibility="Auto"
                   Visibility="{Binding Selected.IsText, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />

          <!-- image preview -->
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                        Visibility="{Binding Selected.IsImage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Image Source="{Binding Selected.Image}" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
