<UserControl x:Class="WinDeploy.App.Views.FtpClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <Style x:Key="Lbl" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
      <Setter Property="Margin" Value="0,0,0,3" />
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- connection form -->
    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="主机" Style="{StaticResource Lbl}" />
            <TextBox Width="220" Padding="8,5" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="端口" Style="{StaticResource Lbl}" />
            <TextBox Width="70" Padding="8,5" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="用户名" Style="{StaticResource Lbl}" />
            <TextBox Width="140" Padding="8,5" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
          </StackPanel>
          <StackPanel>
            <TextBlock Text="密码" Style="{StaticResource Lbl}" />
            <PasswordBox x:Name="PwBox" Width="140" Padding="8,5"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderStrong}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
          <RadioButton Content="明文" GroupName="cliTls" IsChecked="{Binding IsTlsNone}" Margin="0,0,14,0" />
          <RadioButton Content="显式 TLS" GroupName="cliTls" IsChecked="{Binding IsTlsExplicit}" Margin="0,0,14,0" />
          <RadioButton Content="隐式 TLS" GroupName="cliTls" IsChecked="{Binding IsTlsImplicit}" Margin="0,0,20,0" />
          <Button Content="连接" Style="{StaticResource OkButton}" Margin="0,0,8,0" Command="{Binding ConnectCommand}" />
          <Button Content="断开" Style="{StaticResource DangerButton}" Command="{Binding DisconnectCommand}" />
          <TextBlock Text="{Binding StatusText}" FontSize="12.5" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Connected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource OkFg}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- dual pane -->
    <Grid Grid.Row="1" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- local -->
      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="本地" FontWeight="SemiBold" FontSize="13" Margin="12,10,12,2" />
          <DockPanel Grid.Row="1" Margin="10,0,10,6">
            <Button DockPanel.Dock="Left" Content="↑ 上级" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding LocalUpCommand}" />
            <Button DockPanel.Dock="Left" Content="选择目录" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding PickLocalCommand}" />
            <Button DockPanel.Dock="Right" Content="上传 →" Style="{StaticResource InfoButton}" Command="{Binding UploadCommand}" />
            <TextBlock Text="{Binding LocalDir}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="6,0,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding LocalDir}" />
          </DockPanel>
          <DataGrid x:Name="LocalGrid" Grid.Row="2" ItemsSource="{Binding LocalEntries}" SelectedItem="{Binding SelectedLocal}"
                    AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                    GridLinesVisibility="Horizontal" Background="Transparent" Margin="6,0,6,6"
                    MouseDoubleClick="LocalGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="28">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
              <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="Auto" />
              <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedText}" Width="Auto" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- remote -->
      <Border Grid.Column="2" Style="{StaticResource Card}" Padding="2">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="远端" FontWeight="SemiBold" FontSize="13" Margin="12,10,12,2" />
          <DockPanel Grid.Row="1" Margin="10,0,10,6">
            <Button DockPanel.Dock="Left" Content="↑ 上级" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding RemoteUpCommand}" />
            <Button DockPanel.Dock="Left" Content="↻" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding RefreshRemoteCommand}" />
            <Button DockPanel.Dock="Left" Content="新建目录" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding MkdirRemoteCommand}" />
            <Button DockPanel.Dock="Right" Content="删除" Style="{StaticResource DangerButton}" Command="{Binding DeleteRemoteCommand}" />
            <Button DockPanel.Dock="Right" Content="重命名" Style="{StaticResource MiniButton}" Margin="0,0,6,0" Command="{Binding RenameRemoteCommand}" />
            <Button DockPanel.Dock="Right" Content="← 下载" Style="{StaticResource InfoButton}" Margin="0,0,6,0" Command="{Binding DownloadCommand}" />
            <TextBlock Text="{Binding RemoteDir}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="6,0,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding RemoteDir}" />
          </DockPanel>
          <Grid Grid.Row="2">
            <TextBlock Text="未连接，或目录为空。" FontSize="12.5" Foreground="{DynamicResource TextSecondary}"
                       Margin="14,10,0,0" VerticalAlignment="Top"
                       Visibility="{Binding NoRemote, Converter={StaticResource BoolToVis}}" />
            <DataGrid x:Name="RemoteGrid" ItemsSource="{Binding RemoteEntries}" SelectedItem="{Binding SelectedRemote}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" Background="Transparent" Margin="6,0,6,6"
                      MouseDoubleClick="RemoteGrid_MouseDoubleClick">
              <DataGrid.Columns>
                <DataGridTemplateColumn Width="28">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="Auto" />
                <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedText}" Width="Auto" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <TextBlock Grid.Row="2" Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="2,8,0,0" TextWrapping="Wrap" />

    <!-- log -->
    <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,8,0,0" Height="110">
      <TextBox x:Name="LogBox" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
               FontFamily="Consolas" FontSize="11" BorderThickness="0" Background="Transparent"
               VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" Margin="8,6" />
    </Border>
  </Grid>
</UserControl>
