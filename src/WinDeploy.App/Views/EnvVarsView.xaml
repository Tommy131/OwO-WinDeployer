<UserControl x:Class="WinDeploy.App.Views.EnvVarsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="环境变量" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="查看 / 编辑用户或系统环境变量。改后对新打开的程序与终端生效。" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <RadioButton Content="用户变量" IsChecked="{Binding IsUser}" GroupName="scope" VerticalAlignment="Center" />
      <RadioButton Content="系统变量" IsChecked="{Binding IsMachine}" GroupName="scope" VerticalAlignment="Center" Margin="16,0,0,0" />
      <Button Content="添加" Style="{StaticResource MiniButton}" Command="{Binding AddCommand}" Margin="24,0,0,0" />
      <Button Content="删除选中" Style="{StaticResource MiniButton}" Command="{Binding RemoveCommand}" Margin="8,0,0,0" />
      <Button Content="重新加载" Style="{StaticResource MiniButton}" Command="{Binding ReloadCommand}" Margin="8,0,0,0" />
      <Button Content="保存" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Margin="8,0,0,0" />
    </StackPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="2" Margin="0,12,0,0">
      <DataGrid ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent"
                BorderThickness="0" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                Foreground="{DynamicResource TextPrimary}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="变量名" Binding="{Binding Name}" Width="240" />
          <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <TextBlock Grid.Row="3" Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="2,10,0,0" />
  </Grid>
</UserControl>
