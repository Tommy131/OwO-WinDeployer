<UserControl x:Class="WinDeploy.App.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="导出" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="扫描本机、把已装软件的配置采集回仓库（敏感信息自动脱敏）。只写仓库，不改本机。"
                 FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
      <Button Content="采集本机配置" Style="{StaticResource PrimaryButton}" Command="{Binding ExportCommand}" />
      <TextBlock Text="处理中 …" Foreground="{StaticResource Accent}" Margin="14,0,0,0" VerticalAlignment="Center"
                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
    </StackPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14,4,14,4" Margin="0,14,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Results}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="2,8">
                <Grid>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontSize="13" />
                    <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{StaticResource TextSecondary}"
                               Margin="10,0,0,0" VerticalAlignment="Center" />
                  </StackPanel>
                  <Border x:Name="Pill" HorizontalAlignment="Right" CornerRadius="10" Padding="9,2" Background="{StaticResource OkBg}">
                    <TextBlock x:Name="PillText" Text="完成" FontSize="11" Foreground="{StaticResource OkFg}" />
                  </Border>
                </Grid>
              </Border>
              <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="failed">
                  <Setter TargetName="Pill" Property="Background" Value="{StaticResource FailBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{StaticResource FailFg}" />
                  <Setter TargetName="PillText" Property="Text" Value="失败" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="skip">
                  <Setter TargetName="Pill" Property="Background" Value="{StaticResource PageBg}" />
                  <Setter TargetName="PillText" Property="Foreground" Value="{StaticResource TextSecondary}" />
                  <Setter TargetName="PillText" Property="Text" Value="跳过" />
                </DataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="3" Background="{StaticResource OkBg}" CornerRadius="8" Padding="12" Margin="0,12,0,0"
            Visibility="{Binding Done, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="已写回 configs/，记得在仓库里 git commit。" Foreground="{StaticResource OkFg}" />
    </Border>
  </Grid>
</UserControl>
