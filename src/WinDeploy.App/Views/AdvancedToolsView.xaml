<UserControl x:Class="WinDeploy.App.Views.AdvancedToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="高级工具" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="面向专业 / 开发人员：环境体检、catalog 校验、版本锁定、winget DSC 导出、离线部署包、迁移工具包、主机预设映射。"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <WrapPanel Grid.Row="1" Margin="0,14,0,0">
      <Button Content="环境体检" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding DoctorCommand}" />
      <Button Content="校验 catalog" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding ValidateCommand}" />
      <Button Content="生成 lock.json" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding LockCommand}" />
      <Button Content="导出 winget DSC" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding DscCommand}" />
      <Button Content="离线部署包" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding OfflineCommand}" />
      <Button Content="迁移包·导出" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding MigrateExportCommand}" />
      <Button Content="迁移包·还原" Style="{StaticResource InfoButton}" Margin="0,0,8,8" Command="{Binding MigrateImportCommand}" />
      <Button Content="编辑主机预设" Style="{StaticResource MiniButton}" Margin="0,0,8,8" Command="{Binding EditHostsCommand}" />
      <Button Content="清空输出" Style="{StaticResource MiniButton}" Margin="0,0,8,8" Command="{Binding ClearCommand}" />
    </WrapPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="2" Margin="0,4,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <TextBox Text="{Binding Output, Mode=OneWay}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                 FontFamily="Consolas" FontSize="12.5" TextWrapping="Wrap" VerticalScrollBarVisibility="Disabled" />
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
