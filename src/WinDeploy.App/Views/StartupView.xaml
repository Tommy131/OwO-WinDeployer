<UserControl x:Class="WinDeploy.App.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="启动项" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="管理 Windows 开机自启动（注册表 Run 键 + 启动文件夹）：启用 / 禁用 / 删除。HKLM 与公共启动项需以管理员身份运行。"
                 FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="↻ 刷新" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
      <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                 VerticalAlignment="Center" Margin="16,0,0,0" />
    </StackPanel>

    <!-- Margin right -24 / Padding right 24: scrollbar flush at the page's outer edge, content unchanged. -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,12,-24,0" Padding="0,0,24,0">
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,10">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- icon -->
                <Grid Grid.Column="0" Width="34" Height="34" VerticalAlignment="Top">
                  <Border CornerRadius="8" Background="{DynamicResource PageBg}"
                          Visibility="{Binding ShowLetter, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding Badge}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <Image Source="{Binding IconImage}" Stretch="Uniform" Margin="2"
                         Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
                         RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>

                <!-- name / source / command -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="280" />
                    <Border CornerRadius="6" Padding="6,1" Margin="8,0,0,0" Background="{DynamicResource PageBg}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource TextSecondary}" />
                    </Border>
                    <Border CornerRadius="6" Padding="6,1" Margin="5,0,0,0" Background="{DynamicResource OkBg}" VerticalAlignment="Center"
                            Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="已启用" FontSize="10" Foreground="{DynamicResource OkFg}" />
                    </Border>
                    <Border CornerRadius="6" Padding="6,1" Margin="5,0,0,0" Background="{DynamicResource FailBg}" VerticalAlignment="Center"
                            Visibility="{Binding Disabled, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="已禁用" FontSize="10" Foreground="{DynamicResource FailFg}" />
                    </Border>
                    <Border CornerRadius="6" Padding="6,1" Margin="5,0,0,0" Background="{DynamicResource WarnBg}" VerticalAlignment="Center"
                            Visibility="{Binding NeedsAdmin, Converter={StaticResource BoolToVis}}" ToolTip="修改此项需以管理员身份运行">
                      <TextBlock Text="需管理员" FontSize="10" Foreground="{DynamicResource WarnFg}" />
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Command}" FontSize="11.5" FontFamily="Consolas" Foreground="{DynamicResource TextTertiary}"
                             TextTrimming="CharacterEllipsis" Margin="0,4,0,0" ToolTip="{Binding Command}" />
                </StackPanel>

                <!-- actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                  <Button Content="{Binding ToggleLabel}" Style="{StaticResource MiniButton}"
                          Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                  <Button Content="打开位置" Style="{StaticResource MiniButton}" Margin="8,0,0,0"
                          Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                  <Button Content="删除" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                          Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
