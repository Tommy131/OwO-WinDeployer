<UserControl x:Class="WinDeploy.App.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="24,18,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="日志" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="全局审计记录：应用启动、安装 / 更新 / 卸载 / 启动、设置与环境变量变更等。" FontSize="13"
                 Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
      <Button Content="刷新" Style="{StaticResource MiniButton}" Command="{Binding RefreshCommand}" />
      <Button Content="打开目录" Style="{StaticResource MiniButton}" Command="{Binding OpenFolderCommand}" Margin="8,0,0,0" />
      <Button Content="清空" Style="{StaticResource MiniButton}" Command="{Binding ClearCommand}" Margin="8,0,0,0"
              ToolTip="清空 app.log（不可恢复）" />
      <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="{DynamicResource TextTertiary}"
                 VerticalAlignment="Center" Margin="16,0,0,0" TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="2" Margin="0,12,0,0">
      <TextBox x:Name="OutBox" Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap" BorderThickness="0"
               Background="Transparent" VerticalContentAlignment="Top" Padding="10"
               VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
               TextChanged="OutBox_TextChanged" />
    </Border>
  </Grid>
</UserControl>
